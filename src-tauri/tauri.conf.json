{
  "productName": "kora",
  "version": "0.1.0",
  "identifier": "com.kora.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../priv/static"
  },
  "app": {
    "windows": [
      {
        "title": "Kora",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/kora"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
