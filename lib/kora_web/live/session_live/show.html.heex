<div class="h-screen flex flex-col bg-background">
  <div id="session-models-cache" phx-hook="ModelsCache" class="hidden" aria-hidden="true"></div>
  <!-- Header -->
  <header class="h-14 border-b flex items-center justify-between px-4 bg-card shrink-0 z-10">
    <div class="flex items-center gap-4">
      <.link
        navigate={~p"/"}
        class="p-2 -ml-2 rounded-md hover:bg-accent text-muted-foreground hover:text-foreground transition-colors"
      >
        <.icon name="hero-arrow-left" class="w-5 h-5" />
      </.link>
      <div class="flex flex-col">
        <h1 class="font-semibold text-sm max-w-md truncate leading-tight">{@session.goal}</h1>
        <div class="text-[10px] text-muted-foreground flex items-center gap-2">
          <span class={"w-1.5 h-1.5 rounded-full " <> if(@session.status == "active", do: "bg-green-500", else: "bg-gray-400")}>
          </span>
          <span class="uppercase tracking-wider">{@session.status}</span>
          <span class="text-border">|</span>
          <span>{Calendar.strftime(@session.inserted_at, "%b %d, %H:%M")}</span>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <.link
        navigate={~p"/"}
        class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        <.icon name="hero-plus" class="w-4 h-4" />
        New chat
      </.link>
    </div>
  </header>

  <div class="flex-1 flex overflow-hidden">
    <!-- Sidebar: Agent Tree -->
    <div class="w-72 border-r bg-muted/30 flex flex-col overflow-hidden shrink-0">
      <div class="p-3 border-b text-xs font-semibold text-muted-foreground uppercase tracking-wider bg-muted/10">
        Agent Hierarchy
      </div>
      <div class="flex-1 overflow-y-auto p-2">
        <.agent_tree nodes={@agent_tree} selected_id={@selected_agent && @selected_agent.id} expanded_agents={@expanded_agents} />
      </div>
    </div>
    
<!-- Main Content: Chat -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background relative">
      <%= if @selected_agent do %>
        <!-- Agent Header -->
        <div class="h-12 border-b flex items-center justify-between px-6 bg-background/50 backdrop-blur-sm sticky top-0 z-10">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold border border-primary/20">
              {String.slice(@selected_agent.name, 0, 2) |> String.upcase()}
            </div>
            <div>
              <div class="font-medium text-sm leading-none">{@selected_agent.name}</div>
              <form phx-change="change_model" class="inline">
                <select
                  name="model"
                  class="text-[10px] rounded border border-transparent bg-transparent text-muted-foreground hover:border-border focus:ring-0 focus:border-primary cursor-pointer"
                  title="Switch model for this agent (applies on next message or Continue)"
                >
                  <%= for {label, value} <- @available_models do %>
                    <option value={value} selected={@selected_agent.model == value}>{label}</option>
                  <% end %>
                </select>
              </form>
            </div>
          </div>

          <button
            phx-click="toggle_spawn_modal"
            class="text-xs flex items-center gap-1.5 px-3 py-1.5 rounded-md hover:bg-accent transition-colors border border-dashed border-border hover:border-primary/50"
          >
            <.icon name="hero-plus" class="w-3 h-3" />
            <span>Spawn Subagent</span>
          </button>
        </div>
        
<!-- Messages Area -->
        <div
          class="flex-1 overflow-y-auto p-6 space-y-8 scroll-smooth"
          id="messages-container"
          phx-hook="ScrollDown"
        >
          
<!-- Initial Goal Message (Synthetic) -->
          <div class="flex gap-4 justify-end">
            <div class="max-w-[85%] rounded-2xl px-5 py-3 bg-primary text-primary-foreground shadow-sm">
              <div class="prose prose-sm prose-invert break-words">
                {@selected_agent.goal}
              </div>
            </div>
          </div>

          <%= for msg <- @messages do %>
            <!-- User Message -->
            <%= if msg.role == "user" do %>
              <div class="flex gap-4 justify-end group">
                <div class="max-w-[85%] rounded-2xl px-5 py-3 bg-primary text-primary-foreground shadow-sm">
                  <%= if msg.content do %>
                    <div class="prose prose-sm prose-invert break-words">
                      {raw(Earmark.as_html!(msg.content))}
                    </div>
                  <% end %>
                </div>
              </div>
            <% else %>
              <%!-- Assistant/Tool Message (collapsible when it has tool_calls or is a tool message) --%>
              <% is_collapsible = (msg.role == "tool" || (msg.tool_calls && msg.tool_calls != [])) %>
              <% is_expanded = MapSet.member?(@expanded_messages, msg.id) %>
              <div class="flex gap-4 group" id={"msg-#{msg.id}"}>
                <div class="w-8 h-8 rounded-full bg-muted border flex items-center justify-center shrink-0 mt-1">
                  <%= if msg.role == "tool" do %>
                    <.icon name="hero-wrench-screwdriver" class="w-4 h-4 text-muted-foreground" />
                  <% else %>
                    <.icon name="hero-cpu-chip" class="w-4 h-4 text-primary" />
                  <% end %>
                </div>

                <div class="flex-1 max-w-[85%] space-y-2">
                  <div class="flex items-center gap-2">
                    <div class="text-xs font-semibold text-muted-foreground ml-1 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">
                      {msg.role}
                    </div>
                    <%= if is_collapsible do %>
                      <button
                        type="button"
                        id={"toggle-msg-#{msg.id}"}
                        phx-hook="PreserveScrollOnToggle"
                        data-scroll-container="#messages-container"
                        phx-click="toggle_message"
                        phx-value-id={msg.id}
                        class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1"
                      >
                        <.icon name={if is_expanded, do: "hero-chevron-down", else: "hero-chevron-right"} class="w-3 h-3" />
                        {if is_expanded, do: "Collapse", else: "Expand"}
                      </button>
                    <% end %>
                  </div>

                  <div class={"rounded-2xl px-5 py-3 border shadow-sm " <> if(msg.role == "tool", do: "bg-muted/30 border-dashed font-mono text-xs", else: "bg-card")}>
                    <%= if is_collapsible && !is_expanded do %>
                      <p class="text-muted-foreground text-sm">
                        <%= if msg.tool_calls && msg.tool_calls != [] do %>
                          {length(msg.tool_calls)} tool call(s): {Enum.map(msg.tool_calls, fn tc -> tc["function"]["name"] end) |> Enum.join(", ")}
                        <% else %>
                          {String.slice(msg.content || "", 0, 80)}{if String.length(msg.content || "") > 80, do: "...", else: ""}
                        <% end %>
                      </p>
                    <% else %>
                      <%= if msg.content && msg.content != "" do %>
                        <div class={"prose prose-sm break-words max-h-[40rem] overflow-y-auto " <> if(msg.role == "tool", do: "max-w-none text-muted-foreground", else: "dark:prose-invert")}>
                          {raw(Earmark.as_html!(msg.content))}
                        </div>
                      <% else %>
                        <%= if msg.role == "assistant" && (!msg.tool_calls || msg.tool_calls == []) do %>
                          <p class="text-muted-foreground italic text-sm">No text in this response.</p>
                        <% end %>
                      <% end %>
                      <%= if msg.tool_calls && msg.tool_calls != [] do %>
                        <div class="mt-3 space-y-2">
                          <%= for tc <- msg.tool_calls do %>
                            <div class="flex items-start gap-2 p-2 rounded bg-muted/50 border text-xs font-mono">
                              <.icon name="hero-command-line" class="w-4 h-4 mt-0.5 text-primary" />
                              <div class="flex-1 overflow-hidden">
                                <div class="font-bold text-foreground">
                                  {tc["function"]["name"]}()
                                </div>
                                <div
                                  class="truncate text-muted-foreground mt-0.5"
                                  title={inspect(tc["function"]["arguments"])}
                                >
                                  {inspect(tc["function"]["arguments"])}
                                </div>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
          
<!-- Streaming Indicator -->
          <%= if @stream_token != "" do %>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-muted border flex items-center justify-center shrink-0 mt-1 animate-pulse">
                <.icon name="hero-cpu-chip" class="w-4 h-4 text-primary" />
              </div>
              <div class="flex-1 max-w-[85%] space-y-2">
                <div class="rounded-2xl px-5 py-3 border bg-card shadow-sm">
                  <div class="prose prose-sm dark:prose-invert break-words">
                    {raw(Earmark.as_html!(@stream_token))}
                    <span class="inline-block w-2 h-4 bg-primary align-middle ml-1 animate-pulse">
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%!-- Working status when agent is running but not streaming (calling tools, waiting for subagents, etc.) --%>
          <%= if @selected_agent.status == :running && @stream_token == "" do %>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-muted border flex items-center justify-center shrink-0 mt-1 animate-pulse">
                <.icon name="hero-cpu-chip" class="w-4 h-4 text-primary" />
              </div>
              <div class="flex-1 max-w-[85%]">
                <div class="rounded-2xl px-5 py-3 border border-dashed bg-muted/30 text-muted-foreground text-sm flex items-center gap-2">
                  <span class="inline-block w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
                  <%= @working_status || "Working..." %>
                </div>
              </div>
            </div>
          <% end %>

          <div class="h-12"></div>
          <!-- Spacer -->
        </div>
        
<!-- Chat Input -->
        <div class="p-4 border-t bg-background">
          <div class="max-w-4xl mx-auto">
            <%= if @selected_agent.status == :failed && @selected_agent.error do %>
              <div class="rounded-lg border border-destructive/50 bg-destructive/10 px-4 py-3 mb-3 text-sm text-destructive">
                <strong>Error:</strong> {@selected_agent.error}
              </div>
            <% end %>
            <%= if @selected_agent.status in [:failed, :done] do %>
              <div class="flex justify-center pb-2">
                <button phx-click="retry_agent" class="btn btn-sm btn-outline gap-2">
                  <.icon name="hero-arrow-path" class="w-4 h-4" />
                  {if @selected_agent.status == :failed, do: "Retry", else: "Continue"}
                </button>
              </div>
            <% end %>

            <.form for={@chat_form} phx-submit="send_message" class="relative">
              <input
                name="content"
                value={@chat_form[:content].value}
                class="w-full rounded-xl border border-input bg-muted/30 px-4 py-3 pr-12 text-sm focus-visible:ring-1 focus-visible:ring-primary shadow-sm"
                placeholder="Type a message..."
                autocomplete="off"
              />
              <button
                type="submit"
                class="absolute right-2 top-2 p-1.5 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
              >
                <.icon name="hero-arrow-up" class="w-4 h-4" />
              </button>
            </.form>
          </div>
        </div>
      <% else %>
        <div class="flex-1 flex flex-col items-center justify-center text-muted-foreground p-8 text-center">
          <div class="w-16 h-16 bg-muted/50 rounded-2xl flex items-center justify-center mb-4">
            <.icon name="hero-squares-2x2" class="w-8 h-8 opacity-50" />
          </div>
          <h3 class="font-medium text-foreground">No Agent Selected</h3>
          <p class="text-sm mt-1 max-w-xs">
            Select an agent from the sidebar to view their progress and logs.
          </p>
        </div>
      <% end %>
    </div>
  </div>
  
<!-- Spawn Modal -->
  <%= if @spawn_modal do %>
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div class="bg-card border p-6 rounded-xl shadow-2xl w-full max-w-md animate-in fade-in zoom-in-95 duration-200">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-bold">Spawn Subagent</h3>
          <button
            phx-click="toggle_spawn_modal"
            class="text-muted-foreground hover:text-foreground"
          >
            <.icon name="hero-x-mark" class="w-5 h-5" />
          </button>
        </div>

        <.form for={@spawn_form} phx-submit="spawn_subagent">
          <div class="space-y-4">
            <div class="space-y-2">
              <.label>Agent Name</.label>
              <input
                type="text"
                name="name"
                required
                placeholder="e.g., researcher"
                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
              />
            </div>
            <div class="space-y-2">
              <.label>Goal</.label>
              <textarea
                name="goal"
                required
                placeholder="Describe the specific task..."
                class="flex min-h-[80px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
              ></textarea>
            </div>
            <div class="flex justify-end gap-3 pt-2">
              <button
                type="button"
                phx-click="toggle_spawn_modal"
                class="px-4 py-2 text-sm font-medium rounded-md hover:bg-accent transition-colors"
              >
                Cancel
              </button>
              <button
                type="submit"
                class="px-4 py-2 text-sm font-medium rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
              >
                Spawn Agent
              </button>
            </div>
          </div>
        </.form>
      </div>
    </div>
  <% end %>
</div>
